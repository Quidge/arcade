{{define "content"}}
<style>
	.lobby-code {
		font-size: 1.05rem;
		color: var(--muted);
		margin: 0 0 1.5rem;
	}
	.lobby-code code {
		font-size: 1.8rem;
		font-weight: 600;
		color: var(--fg);
		letter-spacing: 0.05em;
		background: var(--surface);
		border: 1px solid var(--border);
		padding: 0.25rem 0.6rem;
		border-radius: 0.4rem;
		display: inline-block;
		margin-right: 0.5rem;
	}
	.lobby-panel {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.6rem;
		padding: 1.5rem;
		margin-bottom: 1.25rem;
	}
	.lobby-panel h2 {
		margin: 0 0 0.75rem;
		font-size: 1.1rem;
		font-weight: 600;
	}
	.lobby-error {
		margin-top: 0.75rem;
		padding: 0.6rem 0.75rem;
		background: var(--danger-bg);
		color: var(--danger-fg);
		border-radius: 0.4rem;
		font-size: 0.95rem;
	}
	.roster-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.roster-list li {
		padding: 0.55rem 0;
		border-bottom: 1px solid var(--border);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.roster-list li:last-child { border-bottom: none; }
	.roster-list .self { color: var(--accent-strong); font-weight: 500; }
	.roster-list li.disconnected { color: var(--muted); }
	.roster-list li.disconnected .self { color: var(--muted); }
	.disconnected-tag {
		font-size: 0.78rem;
		color: var(--muted);
		font-style: italic;
		margin-left: 0.35rem;
	}
	.roster-actions {
		margin-left: auto;
		display: flex;
		gap: 0.4rem;
	}
	.roster-actions .btn-mini {
		font-size: 0.78rem;
		padding: 0.2rem 0.55rem;
		border-radius: 0.3rem;
		border: 1px solid var(--border);
		background: var(--surface);
		color: var(--fg);
		cursor: pointer;
	}
	.roster-actions .btn-mini:hover { background: var(--badge-bg); }
	.roster-actions .btn-mini.danger { color: var(--danger-fg); }
	.leave-row {
		margin-top: 0.75rem;
		display: flex;
		justify-content: flex-end;
	}
	.notice-stack {
		margin-top: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}
	.notice {
		padding: 0.45rem 0.65rem;
		background: var(--badge-bg);
		color: var(--badge-fg);
		border-radius: 0.35rem;
		font-size: 0.9rem;
	}
	.host-badge {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		background: var(--badge-bg);
		color: var(--badge-fg);
		padding: 0.1rem 0.5rem;
		border-radius: 0.25rem;
	}
	.roster-empty {
		color: var(--muted);
		font-style: italic;
	}
	.share-row {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	.share-row .input { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
	.hidden { display: none !important; }
	.status-line {
		font-size: 0.9rem;
		color: var(--muted);
		margin-top: 0.5rem;
	}
	.status-line.connected { color: var(--accent-strong); }
	.host-controls {
		margin-top: 0.75rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--border);
		display: flex;
		gap: 0.75rem;
		align-items: center;
		flex-wrap: wrap;
	}
	.host-controls label {
		font-size: 0.9rem;
		color: var(--muted);
	}
	.host-controls select {
		padding: 0.4rem 0.6rem;
		border: 1px solid var(--border);
		border-radius: 0.4rem;
		background: var(--surface);
		font-family: inherit;
		font-size: 0.95rem;
	}
	.host-controls .btn { padding: 0.5rem 1rem; }
	.round-prompt {
		font-size: 1.15rem;
		color: var(--fg);
		margin: 0 0 0.4rem;
	}
	.round-hint {
		color: var(--muted);
		font-size: 0.9rem;
		margin: 0 0 1rem;
	}
	.round-textarea {
		width: 100%;
		min-height: 4.5rem;
		padding: 0.6rem 0.75rem;
		border: 1px solid var(--border);
		border-radius: 0.4rem;
		font-size: 1rem;
		font-family: inherit;
		background: var(--surface);
		resize: vertical;
	}
	.round-textarea:focus { outline: 2px solid var(--accent); border-color: transparent; }
	.round-textarea[disabled] {
		background: var(--bg);
		color: var(--muted);
		cursor: not-allowed;
	}
	.round-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 0.75rem;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.round-countdown {
		font-variant-numeric: tabular-nums;
		color: var(--muted);
		font-size: 0.95rem;
	}
	.round-countdown.urgent { color: var(--danger-fg); font-weight: 600; }
	.round-actions { display: flex; gap: 0.5rem; }
	.round-submitted {
		margin-top: 0.5rem;
		padding: 0.45rem 0.65rem;
		background: var(--badge-bg);
		color: var(--badge-fg);
		border-radius: 0.35rem;
		font-size: 0.9rem;
	}
	.round-complete {
		font-size: 1.1rem;
		color: var(--muted);
		margin: 0 0 0.75rem;
	}
</style>

<h1>Lobby</h1>
<p class="lobby-code">
	Code: <code>{{.DisplayCode}}</code>
</p>

<section id="name-panel" class="lobby-panel">
	<h2>Pick a display name</h2>
	<form id="name-form" class="field-row">
		<label class="sr-only" for="name-input">Display name</label>
		<input class="input" id="name-input" name="name" required autocomplete="off"
			maxlength="32" placeholder="e.g. Alice">
		<button class="btn" type="submit" id="name-submit">Join</button>
	</form>
	<div id="name-error" class="lobby-error hidden" role="alert"></div>
</section>

<section id="connected-panel" class="lobby-panel hidden">
	<h2>Players</h2>
	<ul id="roster" class="roster-list"></ul>
	<div id="host-controls" class="host-controls hidden">
		<label for="timer-select">Round timer</label>
		<select id="timer-select">
			<option value="60" selected>60 s</option>
			<option value="15">15 s</option>
			<option value="30">30 s</option>
			<option value="45">45 s</option>
			<option value="75">75 s</option>
			<option value="90">90 s</option>
			<option value="105">105 s</option>
			<option value="120">120 s</option>
			<option value="0">off</option>
		</select>
		<button id="start-btn" class="btn" type="button">Start</button>
	</div>
	<div class="leave-row">
		<button id="leave-btn" class="btn-mini danger" type="button">Leave game</button>
	</div>
	<div id="notice-stack" class="notice-stack"></div>
	<p id="status" class="status-line connected">Connected.</p>
</section>

<section id="round-panel" class="lobby-panel hidden">
	<h2>Round 0 — Starter Caption</h2>
	<p class="round-prompt">Invent the first Caption for your Chain.</p>
	<p class="round-hint">One sentence. Anything goes.</p>
	<textarea id="round-input" class="round-textarea" maxlength="500" placeholder="e.g. a cat playing a tiny piano"></textarea>
	<div id="round-submitted-banner" class="round-submitted hidden">Submitted — waiting for others…</div>
	<div class="round-row">
		<span id="round-countdown" class="round-countdown"></span>
		<span class="round-actions">
			<button id="round-submit-btn" class="btn" type="button">Submit</button>
			<button id="round-advance-btn" class="btn-mini danger hidden" type="button">Force advance</button>
		</span>
	</div>
</section>

<section id="round-complete-panel" class="lobby-panel hidden">
	<h2>Round 0 complete</h2>
	<p class="round-complete">More game flow coming soon.</p>
</section>

<section id="share-panel" class="lobby-panel hidden">
	<h2>Share this lobby</h2>
	<div class="share-row">
		<input id="share-link" class="input" type="text" readonly>
		<button id="copy-link" class="btn" type="button">Copy link</button>
	</div>
	<p class="status-line"><span id="copy-status"></span>&nbsp;</p>
</section>

<script>
(function () {
	const code = "{{.Code}}";

	const namePanel = document.getElementById("name-panel");
	const nameForm = document.getElementById("name-form");
	const nameInput = document.getElementById("name-input");
	const nameSubmit = document.getElementById("name-submit");
	const nameError = document.getElementById("name-error");

	const connectedPanel = document.getElementById("connected-panel");
	const roster = document.getElementById("roster");
	const leaveBtn = document.getElementById("leave-btn");
	const noticeStack = document.getElementById("notice-stack");
	const status = document.getElementById("status");

	const hostControls = document.getElementById("host-controls");
	const timerSelect = document.getElementById("timer-select");
	const startBtn = document.getElementById("start-btn");

	const roundPanel = document.getElementById("round-panel");
	const roundInput = document.getElementById("round-input");
	const roundCountdown = document.getElementById("round-countdown");
	const roundSubmitBtn = document.getElementById("round-submit-btn");
	const roundAdvanceBtn = document.getElementById("round-advance-btn");
	const roundSubmittedBanner = document.getElementById("round-submitted-banner");
	const roundCompletePanel = document.getElementById("round-complete-panel");

	const sharePanel = document.getElementById("share-panel");
	const shareLink = document.getElementById("share-link");
	const copyBtn = document.getElementById("copy-link");
	const copyStatus = document.getElementById("copy-status");

	let phase = "lobby"; // "lobby" | "round" | "complete"
	let deadlineMS = null;
	let countdownTimer = null;
	let submitted = false;
	let viewerIsHost = false;

	let myName = null;
	let ws = null;
	// leftVoluntarily is set when the user clicks "Leave game" so
	// the impending WS close handler can return cleanly to name
	// entry without showing a "Disconnected." error.
	let leftVoluntarily = false;

	function showNameError(msg) {
		nameError.textContent = msg;
		nameError.classList.remove("hidden");
	}
	function hideNameError() {
		nameError.classList.add("hidden");
		nameError.textContent = "";
	}

	function sendCmd(cmd) {
		if (!ws || ws.readyState !== WebSocket.OPEN) return;
		try { ws.send(JSON.stringify(cmd)); }
		catch (e) { console.warn("ws send failed", e); }
	}

	function showNotice(text) {
		const div = document.createElement("div");
		div.className = "notice";
		div.textContent = text;
		noticeStack.appendChild(div);
		// Auto-fade after a few seconds so the stack stays short.
		setTimeout(function () {
			if (div.parentNode) div.parentNode.removeChild(div);
		}, 6000);
	}

	function renderRoster(players) {
		roster.innerHTML = "";
		if (!players || players.length === 0) {
			const li = document.createElement("li");
			li.className = "roster-empty";
			li.textContent = "(no one here yet)";
			roster.appendChild(li);
			return;
		}
		// Determine whether the local Player is currently the Host.
		// The "Make Host" and "Kick" affordances render only when
		// the viewer is Host (per issue #7 / ADR 0005). If our seat
		// has been removed from the roster (kick or leave), no row
		// is the viewer so isHost falls back to false.
		viewerIsHost = false;
		for (const p of players) {
			if (p.name === myName && p.host) { viewerIsHost = true; break; }
		}
		// Host-only lobby affordances (timer dropdown + Start) only
		// show in the lobby phase.
		if (viewerIsHost && phase === "lobby") {
			hostControls.classList.remove("hidden");
		} else {
			hostControls.classList.add("hidden");
		}
		// Host-only Round affordance: Force advance.
		if (viewerIsHost && phase === "round") {
			roundAdvanceBtn.classList.remove("hidden");
		} else {
			roundAdvanceBtn.classList.add("hidden");
		}
		for (const p of players) {
			const li = document.createElement("li");
			const nameSpan = document.createElement("span");
			nameSpan.textContent = p.name;
			if (p.name === myName) nameSpan.classList.add("self");
			li.appendChild(nameSpan);
			if (p.host) {
				const badge = document.createElement("span");
				badge.className = "host-badge";
				badge.textContent = "Host";
				li.appendChild(badge);
			}
			if (p.connected === false) {
				li.classList.add("disconnected");
				const tag = document.createElement("span");
				tag.className = "disconnected-tag";
				tag.textContent = "(disconnected)";
				li.appendChild(tag);
			}
			if (viewerIsHost && p.name !== myName) {
				const actions = document.createElement("span");
				actions.className = "roster-actions";

				const makeHost = document.createElement("button");
				makeHost.type = "button";
				makeHost.className = "btn-mini";
				makeHost.textContent = "Make Host";
				makeHost.addEventListener("click", function () {
					sendCmd({ type: "transfer-host", target: p.name });
				});
				actions.appendChild(makeHost);

				const kick = document.createElement("button");
				kick.type = "button";
				kick.className = "btn-mini danger";
				kick.textContent = "Kick";
				kick.addEventListener("click", function () {
					sendCmd({ type: "kick", target: p.name });
				});
				actions.appendChild(kick);

				li.appendChild(actions);
			}
			roster.appendChild(li);
		}
	}

	function onOpen() {
		namePanel.classList.add("hidden");
		connectedPanel.classList.remove("hidden");
		sharePanel.classList.remove("hidden");
		shareLink.value = window.location.origin + window.location.pathname;
	}

	function onMessage(ev) {
		let msg;
		try { msg = JSON.parse(ev.data); }
		catch (e) { console.warn("bad ws message", ev.data); return; }
		if (msg.type === "roster") {
			renderRoster(msg.players);
		} else if (msg.type === "notice" && msg.text) {
			showNotice(msg.text);
		} else if (msg.type === "round-state") {
			enterRound(msg);
		} else if (msg.type === "round-ended") {
			enterRoundComplete();
		}
	}

	function fmtCountdown(ms) {
		if (ms <= 0) return "0:00";
		const total = Math.ceil(ms / 1000);
		const m = Math.floor(total / 60);
		const s = total % 60;
		return m + ":" + (s < 10 ? "0" : "") + s;
	}

	function tickCountdown() {
		if (deadlineMS === null) {
			roundCountdown.textContent = "";
			roundCountdown.classList.remove("urgent");
			return;
		}
		const remaining = deadlineMS - Date.now();
		roundCountdown.textContent = "Time left: " + fmtCountdown(remaining);
		if (remaining <= 10000) {
			roundCountdown.classList.add("urgent");
		} else {
			roundCountdown.classList.remove("urgent");
		}
	}

	function clearCountdown() {
		if (countdownTimer !== null) {
			clearInterval(countdownTimer);
			countdownTimer = null;
		}
	}

	function enterRound(msg) {
		phase = "round";
		deadlineMS = (typeof msg.deadline_ms === "number") ? msg.deadline_ms : null;
		submitted = !!msg.submitted;
		hostControls.classList.add("hidden");
		roundPanel.classList.remove("hidden");
		roundCompletePanel.classList.add("hidden");
		var draftText = "";
		if (msg.draft && typeof msg.draft.text === "string") {
			draftText = msg.draft.text;
		}
		roundInput.value = draftText;
		if (submitted) {
			roundInput.disabled = true;
			roundSubmitBtn.disabled = true;
			roundSubmittedBanner.classList.remove("hidden");
		} else {
			roundInput.disabled = false;
			roundSubmitBtn.disabled = false;
			roundSubmittedBanner.classList.add("hidden");
		}
		if (viewerIsHost) {
			roundAdvanceBtn.classList.remove("hidden");
		} else {
			roundAdvanceBtn.classList.add("hidden");
		}
		clearCountdown();
		tickCountdown();
		if (deadlineMS !== null) {
			countdownTimer = setInterval(tickCountdown, 500);
		}
	}

	function enterRoundComplete() {
		phase = "complete";
		clearCountdown();
		roundPanel.classList.add("hidden");
		hostControls.classList.add("hidden");
		roundCompletePanel.classList.remove("hidden");
	}

	function resetToNameEntry() {
		connectedPanel.classList.add("hidden");
		sharePanel.classList.add("hidden");
		namePanel.classList.remove("hidden");
		nameSubmit.disabled = false;
		renderRoster([]);
	}

	function onClose(ev) {
		ws = null;
		const reason = ev.reason || "";

		// User clicked "Leave game." The local UI was already
		// reset; the WS close that follows is just cleanup, not
		// an error condition to surface.
		if (leftVoluntarily) {
			leftVoluntarily = false;
			return;
		}

		// Server-driven rejections (policy violations from the WS
		// handler) arrive after the upgrade-handshake "open" event,
		// so we may already be showing the connected UI. Always
		// reset to name entry for these.
		if (reason.indexOf("session full") === 0) {
			resetToNameEntry();
			showNameError("This game session is full (8 players maximum).");
			return;
		}
		if (reason.indexOf("superseded") === 0) {
			// Another connection (refresh, second tab, or impostor)
			// took over this seat. The new connection owns the seat
			// now; this tab is informational.
			status.classList.remove("connected");
			status.textContent = "This seat was taken over by another connection.";
			return;
		}
		if (reason.indexOf("kicked") === 0) {
			// The Host removed us from the GameSession. The seat is
			// gone; reset back to name entry so the user can try a
			// different name or join a different session.
			resetToNameEntry();
			showNameError("You were removed from this game session by the host.");
			return;
		}

		// Real disconnect after a successful join.
		if (!connectedPanel.classList.contains("hidden")) {
			status.classList.remove("connected");
			status.textContent = "Disconnected" + (reason ? ": " + reason : ".");
			return;
		}

		nameSubmit.disabled = false;
		if (ev.code === 1006) {
			showNameError("Connection lost before joining. Please try again.");
		} else {
			showNameError(reason || "could not connect");
		}
	}

	nameForm.addEventListener("submit", function (e) {
		e.preventDefault();
		hideNameError();
		const name = nameInput.value.trim();
		if (!name) return;
		myName = name;
		nameSubmit.disabled = true;

		const proto = window.location.protocol === "https:" ? "wss:" : "ws:";
		const url = proto + "//" + window.location.host + "/g/" + code + "/ws?name=" + encodeURIComponent(name);
		try {
			ws = new WebSocket(url);
		} catch (err) {
			nameSubmit.disabled = false;
			showNameError("Could not open WebSocket: " + err.message);
			return;
		}
		ws.addEventListener("open", onOpen);
		ws.addEventListener("message", onMessage);
		ws.addEventListener("close", onClose);
		ws.addEventListener("error", function () {
			// onClose will follow; let it handle the user-facing reset.
		});
	});

	timerSelect.addEventListener("change", function () {
		const v = timerSelect.value;
		const secs = v === "0" ? null : parseInt(v, 10);
		sendCmd({ type: "timer", seconds: secs });
	});

	startBtn.addEventListener("click", function () {
		// Push the current dropdown value first so the server's
		// pending-timer state matches what the Host has selected,
		// then issue Start. Both messages travel over the same WS
		// in order, so the server processes them sequentially.
		const v = timerSelect.value;
		const secs = v === "0" ? null : parseInt(v, 10);
		sendCmd({ type: "timer", seconds: secs });
		sendCmd({ type: "start" });
	});

	roundInput.addEventListener("input", function () {
		if (phase !== "round" || submitted) return;
		sendCmd({ type: "draft", text: roundInput.value });
	});

	roundSubmitBtn.addEventListener("click", function () {
		if (phase !== "round" || submitted) return;
		// Push the latest text once more to be safe, then submit.
		sendCmd({ type: "draft", text: roundInput.value });
		sendCmd({ type: "submit" });
		submitted = true;
		roundInput.disabled = true;
		roundSubmitBtn.disabled = true;
		roundSubmittedBanner.classList.remove("hidden");
	});

	roundAdvanceBtn.addEventListener("click", function () {
		if (phase !== "round") return;
		sendCmd({ type: "advance" });
	});

	leaveBtn.addEventListener("click", function () {
		if (!confirm("Leave this game?")) return;
		sendCmd({ type: "leave" });
		// Reset the local UI immediately — the user has decided to
		// leave; we don't need server confirmation to take them
		// back to name entry. The leftVoluntarily flag tells the
		// upcoming WS close handler to skip its disconnect/error UI.
		leftVoluntarily = true;
		hideNameError();
		resetToNameEntry();
		try { if (ws) ws.close(); } catch (e) {}
	});

	copyBtn.addEventListener("click", function () {
		const url = shareLink.value;
		const writeText = (navigator.clipboard && navigator.clipboard.writeText)
			? navigator.clipboard.writeText(url)
			: Promise.reject(new Error("no clipboard"));
		writeText.then(function () {
			copyStatus.textContent = "Copied!";
			setTimeout(function () { copyStatus.textContent = ""; }, 1500);
		}).catch(function () {
			shareLink.select();
			copyStatus.textContent = "Selected — press Cmd/Ctrl+C to copy.";
		});
	});
})();
</script>
{{end}}
