{{define "content"}}
<style>
	.lobby-code {
		font-size: 1.05rem;
		color: var(--muted);
		margin: 0 0 1.5rem;
	}
	.lobby-code code {
		font-size: 1.8rem;
		font-weight: 600;
		color: var(--fg);
		letter-spacing: 0.05em;
		background: var(--surface);
		border: 1px solid var(--border);
		padding: 0.25rem 0.6rem;
		border-radius: 0.4rem;
		display: inline-block;
		margin-right: 0.5rem;
	}
	.lobby-panel {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0.6rem;
		padding: 1.5rem;
		margin-bottom: 1.25rem;
	}
	.lobby-panel h2 {
		margin: 0 0 0.75rem;
		font-size: 1.1rem;
		font-weight: 600;
	}
	.lobby-error {
		margin-top: 0.75rem;
		padding: 0.6rem 0.75rem;
		background: var(--danger-bg);
		color: var(--danger-fg);
		border-radius: 0.4rem;
		font-size: 0.95rem;
	}
	.roster-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.roster-list li {
		padding: 0.55rem 0;
		border-bottom: 1px solid var(--border);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.roster-list li:last-child { border-bottom: none; }
	.roster-list .self { color: var(--accent-strong); font-weight: 500; }
	.roster-list li.disconnected { color: var(--muted); }
	.roster-list li.disconnected .self { color: var(--muted); }
	.disconnected-tag {
		font-size: 0.78rem;
		color: var(--muted);
		font-style: italic;
		margin-left: 0.35rem;
	}
	.roster-actions {
		margin-left: auto;
		display: flex;
		gap: 0.4rem;
	}
	.roster-actions .btn-mini {
		font-size: 0.78rem;
		padding: 0.2rem 0.55rem;
		border-radius: 0.3rem;
		border: 1px solid var(--border);
		background: var(--surface);
		color: var(--fg);
		cursor: pointer;
	}
	.roster-actions .btn-mini:hover { background: var(--badge-bg); }
	.roster-actions .btn-mini.danger { color: var(--danger-fg); }
	.leave-row {
		margin-top: 0.75rem;
		display: flex;
		justify-content: flex-end;
	}
	.notice-stack {
		margin-top: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}
	.notice {
		padding: 0.45rem 0.65rem;
		background: var(--badge-bg);
		color: var(--badge-fg);
		border-radius: 0.35rem;
		font-size: 0.9rem;
	}
	.host-badge {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		background: var(--badge-bg);
		color: var(--badge-fg);
		padding: 0.1rem 0.5rem;
		border-radius: 0.25rem;
	}
	.roster-empty {
		color: var(--muted);
		font-style: italic;
	}
	.share-row {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	.share-row .input { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
	.hidden { display: none !important; }
	.status-line {
		font-size: 0.9rem;
		color: var(--muted);
		margin-top: 0.5rem;
	}
	.status-line.connected { color: var(--accent-strong); }
	.host-controls {
		margin-top: 0.75rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--border);
		display: flex;
		gap: 0.75rem;
		align-items: center;
		flex-wrap: wrap;
	}
	.host-controls label {
		font-size: 0.9rem;
		color: var(--muted);
	}
	.host-controls select {
		padding: 0.4rem 0.6rem;
		border: 1px solid var(--border);
		border-radius: 0.4rem;
		background: var(--surface);
		font-family: inherit;
		font-size: 0.95rem;
	}
	.host-controls .btn { padding: 0.5rem 1rem; }
	.round-prompt {
		font-size: 1.15rem;
		color: var(--fg);
		margin: 0 0 0.4rem;
	}
	.round-hint {
		color: var(--muted);
		font-size: 0.9rem;
		margin: 0 0 1rem;
	}
	.round-textarea {
		width: 100%;
		min-height: 4.5rem;
		padding: 0.6rem 0.75rem;
		border: 1px solid var(--border);
		border-radius: 0.4rem;
		font-size: 1rem;
		font-family: inherit;
		background: var(--surface);
		resize: vertical;
	}
	.round-textarea:focus { outline: 2px solid var(--accent); border-color: transparent; }
	.round-textarea[disabled] {
		background: var(--bg);
		color: var(--muted);
		cursor: not-allowed;
	}
	.round-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 0.75rem;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.round-countdown {
		font-variant-numeric: tabular-nums;
		color: var(--muted);
		font-size: 0.95rem;
	}
	.round-countdown.urgent { color: var(--danger-fg); font-weight: 600; }
	.round-actions { display: flex; gap: 0.5rem; }
	.round-submitted {
		margin-top: 0.5rem;
		padding: 0.45rem 0.65rem;
		background: var(--badge-bg);
		color: var(--badge-fg);
		border-radius: 0.35rem;
		font-size: 0.9rem;
	}
	.round-complete {
		font-size: 1.1rem;
		color: var(--muted);
		margin: 0 0 0.75rem;
	}
	.round-prompt-drawing {
		font-size: 1.15rem;
		font-weight: 500;
		color: var(--fg);
		margin: 0 0 0.75rem;
		padding: 0.6rem 0.75rem;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 0.4rem;
	}
	.canvas-wrap {
		position: relative;
		width: 100%;
		max-width: 32rem;
		aspect-ratio: 1 / 1;
		margin: 0 auto 0.75rem;
		background: #ffffff;
		border: 1px solid var(--border);
		border-radius: 0.4rem;
		touch-action: none;
		overflow: hidden;
	}
	.canvas-wrap canvas {
		width: 100%;
		height: 100%;
		display: block;
		cursor: crosshair;
	}
	.reveal-header {
		font-size: 1.2rem;
		margin: 0 0 0.5rem;
	}
	.reveal-meta {
		color: var(--muted);
		font-size: 0.9rem;
		margin: 0 0 1rem;
	}
	.reveal-driver-pill {
		display: inline-block;
		font-size: 0.78rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		background: var(--badge-bg);
		color: var(--badge-fg);
		padding: 0.1rem 0.5rem;
		border-radius: 0.25rem;
		margin-left: 0.4rem;
	}
	.reveal-entries {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.reveal-entry {
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		padding: 0.75rem;
		background: var(--surface);
	}
	.reveal-entry-head {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin: 0 0 0.5rem;
		font-size: 0.85rem;
		color: var(--muted);
	}
	.reveal-author {
		font-weight: 600;
		color: var(--fg);
	}
	.reveal-ghost-tag {
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		background: var(--badge-bg);
		color: var(--badge-fg);
		padding: 0.1rem 0.5rem;
		border-radius: 0.25rem;
	}
	.reveal-caption {
		font-size: 1.1rem;
		margin: 0;
	}
	.reveal-drawing {
		width: 100%;
		max-width: 24rem;
		aspect-ratio: 1 / 1;
		background: #ffffff;
		border: 1px solid var(--border);
		border-radius: 0.4rem;
		display: block;
		margin: 0;
	}
	.reveal-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 1rem;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.reveal-watching {
		color: var(--muted);
		font-style: italic;
	}
	.end-game-row {
		margin-top: 0.5rem;
		display: flex;
		justify-content: flex-end;
	}
	.ended-panel {
		text-align: center;
		padding: 2rem 1rem;
	}
	.ended-panel h2 {
		font-size: 1.4rem;
		margin: 0 0 0.5rem;
	}
	.ended-panel a {
		color: var(--accent-strong);
	}
</style>

<h1>Lobby</h1>
<p class="lobby-code">
	Code: <code>{{.DisplayCode}}</code>
</p>

<section id="name-panel" class="lobby-panel">
	<h2>Pick a display name</h2>
	<form id="name-form" class="field-row">
		<label class="sr-only" for="name-input">Display name</label>
		<input class="input" id="name-input" name="name" required autocomplete="off"
			maxlength="32" placeholder="e.g. Alice">
		<button class="btn" type="submit" id="name-submit">Join</button>
	</form>
	<div id="name-error" class="lobby-error hidden" role="alert"></div>
</section>

<section id="connected-panel" class="lobby-panel hidden">
	<h2>Players</h2>
	<ul id="roster" class="roster-list"></ul>
	<div id="host-controls" class="host-controls hidden">
		<label for="timer-select">Round timer</label>
		<select id="timer-select">
			<option value="60" selected>60 s</option>
			<option value="15">15 s</option>
			<option value="30">30 s</option>
			<option value="45">45 s</option>
			<option value="75">75 s</option>
			<option value="90">90 s</option>
			<option value="105">105 s</option>
			<option value="120">120 s</option>
			<option value="0">off</option>
		</select>
		<button id="start-btn" class="btn" type="button">Start</button>
	</div>
	<div class="leave-row">
		<button id="leave-btn" class="btn-mini danger" type="button">Leave game</button>
	</div>
	<div id="notice-stack" class="notice-stack"></div>
	<p id="status" class="status-line connected">Connected.</p>
</section>

<section id="round-panel" class="lobby-panel hidden">
	<h2 id="round-heading">Round 0 — Starter Caption</h2>
	<p id="round-prompt-text" class="round-prompt">Invent the first Caption for your Chain.</p>
	<p id="round-hint" class="round-hint">One sentence. Anything goes.</p>
	<textarea id="round-input" class="round-textarea" maxlength="500" placeholder="e.g. a cat playing a tiny piano"></textarea>
	<div id="round-submitted-banner" class="round-submitted hidden">Submitted — waiting for others…</div>
	<div class="round-row">
		<span id="round-countdown" class="round-countdown"></span>
		<span class="round-actions">
			<button id="round-submit-btn" class="btn" type="button">Submit</button>
			<button id="round-advance-btn" class="btn-mini danger hidden" type="button">Force advance</button>
		</span>
	</div>
</section>

<section id="round-draw-panel" class="lobby-panel hidden">
	<h2>Round 1 — Drawing</h2>
	<p id="round-draw-prompt" class="round-prompt-drawing"></p>
	<div class="canvas-wrap">
		<canvas id="round-canvas" width="600" height="600"></canvas>
	</div>
	<div id="round-draw-submitted-banner" class="round-submitted hidden">Submitted — waiting for others…</div>
	<div class="round-row">
		<span id="round-draw-countdown" class="round-countdown"></span>
		<span class="round-actions">
			<button id="round-undo-btn" class="btn-mini" type="button">Undo last stroke</button>
			<button id="round-draw-submit-btn" class="btn" type="button">Submit</button>
			<button id="round-draw-advance-btn" class="btn-mini danger hidden" type="button">Force advance</button>
		</span>
	</div>
</section>

<section id="round-complete-panel" class="lobby-panel hidden">
	<h2 id="round-complete-heading">Round complete</h2>
	<p class="round-complete">Setting up the next step…</p>
</section>

<section id="reveal-panel" class="lobby-panel hidden">
	<h2 id="reveal-header" class="reveal-header"></h2>
	<p id="reveal-meta" class="reveal-meta"></p>
	<div id="reveal-entries" class="reveal-entries"></div>
	<div class="reveal-row">
		<span id="reveal-driver-line" class="reveal-watching"></span>
		<span class="round-actions">
			<button id="reveal-next-btn" class="btn hidden" type="button">Next</button>
		</span>
	</div>
</section>

<section id="ended-panel" class="lobby-panel ended-panel hidden">
	<h2>Thanks for playing!</h2>
	<p>The host ended the game.</p>
	<p><a href="/">Back to home</a></p>
</section>

<section id="host-end-game-panel" class="hidden">
	<div class="end-game-row">
		<button id="end-game-btn" class="btn-mini danger" type="button">End game</button>
	</div>
</section>

<section id="share-panel" class="lobby-panel hidden">
	<h2>Share this lobby</h2>
	<div class="share-row">
		<input id="share-link" class="input" type="text" readonly>
		<button id="copy-link" class="btn" type="button">Copy link</button>
	</div>
	<p class="status-line"><span id="copy-status"></span>&nbsp;</p>
</section>

<script>
(function () {
	const code = "{{.Code}}";

	const namePanel = document.getElementById("name-panel");
	const nameForm = document.getElementById("name-form");
	const nameInput = document.getElementById("name-input");
	const nameSubmit = document.getElementById("name-submit");
	const nameError = document.getElementById("name-error");

	const connectedPanel = document.getElementById("connected-panel");
	const roster = document.getElementById("roster");
	const leaveBtn = document.getElementById("leave-btn");
	const noticeStack = document.getElementById("notice-stack");
	const status = document.getElementById("status");

	const hostControls = document.getElementById("host-controls");
	const timerSelect = document.getElementById("timer-select");
	const startBtn = document.getElementById("start-btn");

	const roundPanel = document.getElementById("round-panel");
	const roundHeading = document.getElementById("round-heading");
	const roundPromptText = document.getElementById("round-prompt-text");
	const roundHint = document.getElementById("round-hint");
	const roundInput = document.getElementById("round-input");
	const roundCountdown = document.getElementById("round-countdown");
	const roundSubmitBtn = document.getElementById("round-submit-btn");
	const roundAdvanceBtn = document.getElementById("round-advance-btn");
	const roundSubmittedBanner = document.getElementById("round-submitted-banner");
	const roundCompletePanel = document.getElementById("round-complete-panel");
	const roundCompleteHeading = document.getElementById("round-complete-heading");

	const roundDrawPanel = document.getElementById("round-draw-panel");
	const roundDrawPrompt = document.getElementById("round-draw-prompt");
	const roundDrawCountdown = document.getElementById("round-draw-countdown");
	const roundDrawSubmitBtn = document.getElementById("round-draw-submit-btn");
	const roundDrawAdvanceBtn = document.getElementById("round-draw-advance-btn");
	const roundUndoBtn = document.getElementById("round-undo-btn");
	const roundDrawSubmittedBanner = document.getElementById("round-draw-submitted-banner");
	const roundCanvas = document.getElementById("round-canvas");

	const revealPanel = document.getElementById("reveal-panel");
	const revealHeaderEl = document.getElementById("reveal-header");
	const revealMetaEl = document.getElementById("reveal-meta");
	const revealEntriesEl = document.getElementById("reveal-entries");
	const revealNextBtn = document.getElementById("reveal-next-btn");
	const revealDriverLine = document.getElementById("reveal-driver-line");

	const endedPanel = document.getElementById("ended-panel");
	const hostEndGamePanel = document.getElementById("host-end-game-panel");
	const endGameBtn = document.getElementById("end-game-btn");

	const sharePanel = document.getElementById("share-panel");
	const shareLink = document.getElementById("share-link");
	const copyBtn = document.getElementById("copy-link");
	const copyStatus = document.getElementById("copy-status");

	let phase = "lobby"; // "lobby" | "round" | "round-draw" | "complete" | "reveal" | "ended"
	let deadlineMS = null;
	let countdownTimer = null;
	let submitted = false;
	let viewerIsHost = false;

	// Drawing state for Round 1 (and any future drawing round).
	let drawStrokes = [];      // [ [{x,y},...], ... ] in normalized 0..1 coords
	let drawingActive = false; // pointer is currently down
	let activeStroke = null;
	let drawingDisabled = false;

	let myName = null;
	let ws = null;
	// leftVoluntarily is set when the user clicks "Leave game" so
	// the impending WS close handler can return cleanly to name
	// entry without showing a "Disconnected." error.
	let leftVoluntarily = false;

	function showNameError(msg) {
		nameError.textContent = msg;
		nameError.classList.remove("hidden");
	}
	function hideNameError() {
		nameError.classList.add("hidden");
		nameError.textContent = "";
	}

	function sendCmd(cmd) {
		if (!ws || ws.readyState !== WebSocket.OPEN) return;
		try { ws.send(JSON.stringify(cmd)); }
		catch (e) { console.warn("ws send failed", e); }
	}

	function showNotice(text) {
		const div = document.createElement("div");
		div.className = "notice";
		div.textContent = text;
		noticeStack.appendChild(div);
		// Auto-fade after a few seconds so the stack stays short.
		setTimeout(function () {
			if (div.parentNode) div.parentNode.removeChild(div);
		}, 6000);
	}

	function renderRoster(players) {
		roster.innerHTML = "";
		if (!players || players.length === 0) {
			const li = document.createElement("li");
			li.className = "roster-empty";
			li.textContent = "(no one here yet)";
			roster.appendChild(li);
			return;
		}
		// Determine whether the local Player is currently the Host.
		// The "Make Host" and "Kick" affordances render only when
		// the viewer is Host (per issue #7 / ADR 0005). If our seat
		// has been removed from the roster (kick or leave), no row
		// is the viewer so isHost falls back to false.
		viewerIsHost = false;
		for (const p of players) {
			if (p.name === myName && p.host) { viewerIsHost = true; break; }
		}
		// Host-only lobby affordances (timer dropdown + Start) only
		// show in the lobby phase.
		if (viewerIsHost && phase === "lobby") {
			hostControls.classList.remove("hidden");
		} else {
			hostControls.classList.add("hidden");
		}
		// Host-only Round affordance: Force advance.
		if (viewerIsHost && phase === "round") {
			roundAdvanceBtn.classList.remove("hidden");
		} else {
			roundAdvanceBtn.classList.add("hidden");
		}
		if (viewerIsHost && phase === "round-draw") {
			roundDrawAdvanceBtn.classList.remove("hidden");
		} else {
			roundDrawAdvanceBtn.classList.add("hidden");
		}
		updateEndGameVisibility();
		for (const p of players) {
			const li = document.createElement("li");
			const nameSpan = document.createElement("span");
			nameSpan.textContent = p.name;
			if (p.name === myName) nameSpan.classList.add("self");
			li.appendChild(nameSpan);
			if (p.host) {
				const badge = document.createElement("span");
				badge.className = "host-badge";
				badge.textContent = "Host";
				li.appendChild(badge);
			}
			if (p.connected === false) {
				li.classList.add("disconnected");
				const tag = document.createElement("span");
				tag.className = "disconnected-tag";
				tag.textContent = "(disconnected)";
				li.appendChild(tag);
			}
			if (viewerIsHost && p.name !== myName) {
				const actions = document.createElement("span");
				actions.className = "roster-actions";

				const makeHost = document.createElement("button");
				makeHost.type = "button";
				makeHost.className = "btn-mini";
				makeHost.textContent = "Make Host";
				makeHost.addEventListener("click", function () {
					sendCmd({ type: "transfer-host", target: p.name });
				});
				actions.appendChild(makeHost);

				const kick = document.createElement("button");
				kick.type = "button";
				kick.className = "btn-mini danger";
				kick.textContent = "Kick";
				kick.addEventListener("click", function () {
					sendCmd({ type: "kick", target: p.name });
				});
				actions.appendChild(kick);

				li.appendChild(actions);
			}
			roster.appendChild(li);
		}
	}

	function onOpen() {
		namePanel.classList.add("hidden");
		connectedPanel.classList.remove("hidden");
		sharePanel.classList.remove("hidden");
		shareLink.value = window.location.origin + window.location.pathname;
	}

	function onMessage(ev) {
		let msg;
		try { msg = JSON.parse(ev.data); }
		catch (e) { console.warn("bad ws message", ev.data); return; }
		if (msg.type === "roster") {
			renderRoster(msg.players);
		} else if (msg.type === "notice" && msg.text) {
			showNotice(msg.text);
		} else if (msg.type === "round-state") {
			enterRound(msg);
		} else if (msg.type === "round-ended") {
			enterRoundComplete(msg);
		} else if (msg.type === "reveal-state") {
			enterReveal(msg);
		} else if (msg.type === "game-ended") {
			enterEnded();
		}
	}

	function fmtCountdown(ms) {
		if (ms <= 0) return "0:00";
		const total = Math.ceil(ms / 1000);
		const m = Math.floor(total / 60);
		const s = total % 60;
		return m + ":" + (s < 10 ? "0" : "") + s;
	}

	function tickCountdown() {
		if (deadlineMS === null) {
			roundCountdown.textContent = "";
			roundCountdown.classList.remove("urgent");
			roundDrawCountdown.textContent = "";
			roundDrawCountdown.classList.remove("urgent");
			return;
		}
		const remaining = deadlineMS - Date.now();
		const txt = "Time left: " + fmtCountdown(remaining);
		roundCountdown.textContent = txt;
		roundDrawCountdown.textContent = txt;
		if (remaining <= 10000) {
			roundCountdown.classList.add("urgent");
			roundDrawCountdown.classList.add("urgent");
		} else {
			roundCountdown.classList.remove("urgent");
			roundDrawCountdown.classList.remove("urgent");
		}
	}

	function redrawCanvas() {
		drawStrokesOnto(roundCanvas, drawStrokes);
	}

	function drawStrokesOnto(canvas, strokes) {
		if (!canvas || !canvas.getContext) return;
		var ctx = canvas.getContext("2d");
		var w = canvas.width;
		var h = canvas.height;
		ctx.fillStyle = "#ffffff";
		ctx.fillRect(0, 0, w, h);
		ctx.strokeStyle = "#000000";
		ctx.lineWidth = Math.max(2, Math.round(w / 200));
		ctx.lineCap = "round";
		ctx.lineJoin = "round";
		for (var i = 0; i < strokes.length; i++) {
			var s = strokes[i];
			if (!s || s.length === 0) continue;
			ctx.beginPath();
			ctx.moveTo(s[0].x * w, s[0].y * h);
			if (s.length === 1) {
				// Render a dot for one-point strokes.
				ctx.lineTo(s[0].x * w + 0.01, s[0].y * h + 0.01);
			} else {
				for (var j = 1; j < s.length; j++) {
					ctx.lineTo(s[j].x * w, s[j].y * h);
				}
			}
			ctx.stroke();
		}
	}

	function canvasPoint(ev) {
		var rect = roundCanvas.getBoundingClientRect();
		var x = (ev.clientX - rect.left) / rect.width;
		var y = (ev.clientY - rect.top) / rect.height;
		if (x < 0) x = 0; if (x > 1) x = 1;
		if (y < 0) y = 0; if (y > 1) y = 1;
		return { x: x, y: y };
	}

	function sendStrokes() {
		sendCmd({ type: "draft", strokes: drawStrokes });
	}

	function clearCountdown() {
		if (countdownTimer !== null) {
			clearInterval(countdownTimer);
			countdownTimer = null;
		}
	}

	function enterRound(msg) {
		const kind = msg.content_kind || "caption";
		deadlineMS = (typeof msg.deadline_ms === "number") ? msg.deadline_ms : null;
		submitted = !!msg.submitted;
		hostControls.classList.add("hidden");
		roundCompletePanel.classList.add("hidden");
		revealPanel.classList.add("hidden");
		endedPanel.classList.add("hidden");
		if (kind === "drawing") {
			phase = "round-draw";
			roundPanel.classList.add("hidden");
			roundDrawPanel.classList.remove("hidden");
			var promptText = "";
			if (msg.prompt && msg.prompt.kind === "caption" && typeof msg.prompt.text === "string") {
				promptText = msg.prompt.text;
			}
			roundDrawPrompt.textContent = promptText;
			drawStrokes = [];
			if (msg.draft && Array.isArray(msg.draft.strokes)) {
				drawStrokes = msg.draft.strokes.map(function (s) {
					return (s || []).map(function (pt) { return { x: pt.x, y: pt.y }; });
				});
			}
			redrawCanvas();
			drawingDisabled = !!submitted;
			roundDrawSubmitBtn.disabled = !!submitted;
			roundUndoBtn.disabled = !!submitted;
			if (submitted) {
				roundDrawSubmittedBanner.classList.remove("hidden");
			} else {
				roundDrawSubmittedBanner.classList.add("hidden");
			}
			if (viewerIsHost) {
				roundDrawAdvanceBtn.classList.remove("hidden");
			} else {
				roundDrawAdvanceBtn.classList.add("hidden");
			}
		} else {
			phase = "round";
			roundDrawPanel.classList.add("hidden");
			roundPanel.classList.remove("hidden");
			if (typeof msg.round === "number") {
				roundHeading.textContent = "Round " + msg.round + " — Starter Caption";
			}
			var draftText = "";
			if (msg.draft && typeof msg.draft.text === "string") {
				draftText = msg.draft.text;
			}
			roundInput.value = draftText;
			if (submitted) {
				roundInput.disabled = true;
				roundSubmitBtn.disabled = true;
				roundSubmittedBanner.classList.remove("hidden");
			} else {
				roundInput.disabled = false;
				roundSubmitBtn.disabled = false;
				roundSubmittedBanner.classList.add("hidden");
			}
			if (viewerIsHost) {
				roundAdvanceBtn.classList.remove("hidden");
			} else {
				roundAdvanceBtn.classList.add("hidden");
			}
		}
		updateEndGameVisibility();
		clearCountdown();
		tickCountdown();
		if (deadlineMS !== null) {
			countdownTimer = setInterval(tickCountdown, 500);
		}
	}

	function enterRoundComplete(msg) {
		phase = "complete";
		clearCountdown();
		roundPanel.classList.add("hidden");
		roundDrawPanel.classList.add("hidden");
		hostControls.classList.add("hidden");
		roundCompletePanel.classList.remove("hidden");
		if (msg && typeof msg === "object" && Array.isArray(msg.entries)) {
			// Heuristic: if the latest finalized entries are drawings,
			// the round we just finished was a drawing round.
			var hadDrawing = msg.entries.some(function (e) { return e.kind === "drawing"; });
			roundCompleteHeading.textContent = hadDrawing
				? "Round complete — drawings sealed"
				: "Round complete — captions sealed";
		}
		updateEndGameVisibility();
	}

	function enterReveal(msg) {
		phase = "reveal";
		clearCountdown();
		hostControls.classList.add("hidden");
		roundPanel.classList.add("hidden");
		roundDrawPanel.classList.add("hidden");
		roundCompletePanel.classList.add("hidden");
		endedPanel.classList.add("hidden");
		revealPanel.classList.remove("hidden");
		var starter = msg.starter || "?";
		revealHeaderEl.textContent = starter + "'s Chain";
		var modeLabel = msg.mode === "complete"
			? "Game over"
			: (msg.mode === "full" ? "Whole chain" : "Step " + ((msg.entries_visible || []).length));
		revealMetaEl.textContent = modeLabel;
		renderRevealEntries(msg.entries_visible || []);
		var driver = msg.driver || "";
		var amDriver = (driver && driver === myName);
		if (msg.mode === "complete") {
			revealNextBtn.classList.add("hidden");
			revealDriverLine.textContent = "Reveal complete — host can end the game.";
		} else if (amDriver) {
			revealNextBtn.classList.remove("hidden");
			revealNextBtn.disabled = false;
			revealDriverLine.textContent = "You're driving.";
		} else {
			revealNextBtn.classList.add("hidden");
			revealDriverLine.textContent = driver ? "Watching — " + driver + " is driving." : "Watching.";
		}
		updateEndGameVisibility();
	}

	function renderRevealEntries(entries) {
		revealEntriesEl.innerHTML = "";
		for (var i = 0; i < entries.length; i++) {
			var e = entries[i];
			var card = document.createElement("div");
			card.className = "reveal-entry";

			var head = document.createElement("div");
			head.className = "reveal-entry-head";
			var label = document.createElement("span");
			label.textContent = "Round " + e.round + " · ";
			head.appendChild(label);
			var author = document.createElement("span");
			author.className = "reveal-author";
			author.textContent = e.author || "?";
			head.appendChild(author);
			if (e.ghost) {
				var tag = document.createElement("span");
				tag.className = "reveal-ghost-tag";
				tag.textContent = e.ghost_label || ((e.author || "?") + "'s Ghost");
				head.appendChild(tag);
			}
			card.appendChild(head);

			if (e.kind === "caption") {
				var p = document.createElement("p");
				p.className = "reveal-caption";
				p.textContent = e.text || "";
				card.appendChild(p);
			} else if (e.kind === "drawing") {
				var canv = document.createElement("canvas");
				canv.className = "reveal-drawing";
				canv.width = 600;
				canv.height = 600;
				card.appendChild(canv);
				// Defer draw until after attach so layout-derived size
				// is available (we draw to the canvas's intrinsic
				// pixel buffer, so layout doesn't matter for fidelity).
				drawStrokesOnto(canv, e.strokes || []);
			}
			revealEntriesEl.appendChild(card);
		}
	}

	function enterEnded() {
		phase = "ended";
		clearCountdown();
		hostControls.classList.add("hidden");
		roundPanel.classList.add("hidden");
		roundDrawPanel.classList.add("hidden");
		roundCompletePanel.classList.add("hidden");
		revealPanel.classList.add("hidden");
		hostEndGamePanel.classList.add("hidden");
		connectedPanel.classList.add("hidden");
		sharePanel.classList.add("hidden");
		endedPanel.classList.remove("hidden");
	}

	function updateEndGameVisibility() {
		// The Host's "End game" button is available throughout the
		// GameSession (from Start onward) and disappears once the
		// game has ended.
		var inGame = (phase === "round" || phase === "round-draw" || phase === "complete" || phase === "reveal");
		if (viewerIsHost && inGame) {
			hostEndGamePanel.classList.remove("hidden");
		} else {
			hostEndGamePanel.classList.add("hidden");
		}
	}

	function resetToNameEntry() {
		connectedPanel.classList.add("hidden");
		sharePanel.classList.add("hidden");
		namePanel.classList.remove("hidden");
		nameSubmit.disabled = false;
		renderRoster([]);
	}

	function onClose(ev) {
		ws = null;
		const reason = ev.reason || "";

		// User clicked "Leave game." The local UI was already
		// reset; the WS close that follows is just cleanup, not
		// an error condition to surface.
		if (leftVoluntarily) {
			leftVoluntarily = false;
			return;
		}

		// Host ended the game. The server broadcasts game-ended,
		// then closes each conn with a normal-closure frame; the
		// client has already entered the "Thanks for playing" view
		// on the preceding envelope. Suppress the disconnect notice
		// — the close is expected and the user already has context.
		if (phase === "ended") {
			return;
		}

		// Server-driven rejections (policy violations from the WS
		// handler) arrive after the upgrade-handshake "open" event,
		// so we may already be showing the connected UI. Always
		// reset to name entry for these.
		if (reason.indexOf("session full") === 0) {
			resetToNameEntry();
			showNameError("This game session is full ({{.MaxPlayers}} players maximum).");
			return;
		}
		if (reason.indexOf("game already started") === 0) {
			resetToNameEntry();
			showNameError("This game has already started. New players cannot join.");
			return;
		}
		if (reason.indexOf("superseded") === 0) {
			// Another connection (refresh, second tab, or impostor)
			// took over this seat. The new connection owns the seat
			// now; this tab is informational.
			status.classList.remove("connected");
			status.textContent = "This seat was taken over by another connection.";
			return;
		}
		if (reason.indexOf("kicked") === 0) {
			// The Host removed us from the GameSession. The seat is
			// gone; reset back to name entry so the user can try a
			// different name or join a different session.
			resetToNameEntry();
			showNameError("You were removed from this game session by the host.");
			return;
		}

		// Real disconnect after a successful join.
		if (!connectedPanel.classList.contains("hidden")) {
			status.classList.remove("connected");
			status.textContent = "Disconnected" + (reason ? ": " + reason : ".");
			return;
		}

		nameSubmit.disabled = false;
		if (ev.code === 1006) {
			showNameError("Connection lost before joining. Please try again.");
		} else {
			showNameError(reason || "could not connect");
		}
	}

	nameForm.addEventListener("submit", function (e) {
		e.preventDefault();
		hideNameError();
		const name = nameInput.value.trim();
		if (!name) return;
		myName = name;
		nameSubmit.disabled = true;

		const proto = window.location.protocol === "https:" ? "wss:" : "ws:";
		const url = proto + "//" + window.location.host + "/g/" + code + "/ws?name=" + encodeURIComponent(name);
		try {
			ws = new WebSocket(url);
		} catch (err) {
			nameSubmit.disabled = false;
			showNameError("Could not open WebSocket: " + err.message);
			return;
		}
		ws.addEventListener("open", onOpen);
		ws.addEventListener("message", onMessage);
		ws.addEventListener("close", onClose);
		ws.addEventListener("error", function () {
			// onClose will follow; let it handle the user-facing reset.
		});
	});

	timerSelect.addEventListener("change", function () {
		const v = timerSelect.value;
		const secs = v === "0" ? null : parseInt(v, 10);
		sendCmd({ type: "timer", seconds: secs });
	});

	startBtn.addEventListener("click", function () {
		// Push the current dropdown value first so the server's
		// pending-timer state matches what the Host has selected,
		// then issue Start. Both messages travel over the same WS
		// in order, so the server processes them sequentially.
		const v = timerSelect.value;
		const secs = v === "0" ? null : parseInt(v, 10);
		sendCmd({ type: "timer", seconds: secs });
		sendCmd({ type: "start" });
	});

	roundInput.addEventListener("input", function () {
		if (phase !== "round" || submitted) return;
		sendCmd({ type: "draft", text: roundInput.value });
	});

	roundSubmitBtn.addEventListener("click", function () {
		if (phase !== "round" || submitted) return;
		// Push the latest text once more to be safe, then submit.
		sendCmd({ type: "draft", text: roundInput.value });
		sendCmd({ type: "submit" });
		submitted = true;
		roundInput.disabled = true;
		roundSubmitBtn.disabled = true;
		roundSubmittedBanner.classList.remove("hidden");
	});

	roundAdvanceBtn.addEventListener("click", function () {
		if (phase !== "round") return;
		sendCmd({ type: "advance" });
	});

	// Drawing-round pointer events. Pointer Events covers mouse,
	// touch, and stylus through one code path. A stroke begins on
	// pointer-down and is captured into activeStroke; intermediate
	// pointer-move events append samples; pointer-up commits the
	// stroke into drawStrokes and ships the full updated list to
	// the server (full-replace per ADR 0010).
	roundCanvas.addEventListener("pointerdown", function (ev) {
		if (phase !== "round-draw" || drawingDisabled) return;
		ev.preventDefault();
		try { roundCanvas.setPointerCapture(ev.pointerId); } catch (e) {}
		drawingActive = true;
		activeStroke = [canvasPoint(ev)];
	});
	roundCanvas.addEventListener("pointermove", function (ev) {
		if (!drawingActive || phase !== "round-draw" || drawingDisabled) return;
		ev.preventDefault();
		activeStroke.push(canvasPoint(ev));
		// Render the in-flight stroke alongside the committed list
		// so the user sees ink as they move.
		var preview = drawStrokes.concat([activeStroke]);
		drawStrokesOnto(roundCanvas, preview);
	});
	function endStroke(ev) {
		if (!drawingActive) return;
		drawingActive = false;
		try { roundCanvas.releasePointerCapture(ev.pointerId); } catch (e) {}
		if (activeStroke && activeStroke.length > 0) {
			drawStrokes.push(activeStroke);
		}
		activeStroke = null;
		redrawCanvas();
		sendStrokes();
	}
	roundCanvas.addEventListener("pointerup", endStroke);
	roundCanvas.addEventListener("pointercancel", endStroke);
	roundCanvas.addEventListener("pointerleave", function (ev) {
		// pointerleave only fires when the pointer exits the canvas
		// while still down; treat it like pointerup so the stroke
		// is committed cleanly.
		if (drawingActive) endStroke(ev);
	});

	roundUndoBtn.addEventListener("click", function () {
		if (phase !== "round-draw" || drawingDisabled) return;
		if (drawStrokes.length === 0) return;
		drawStrokes.pop();
		redrawCanvas();
		sendStrokes();
	});

	roundDrawSubmitBtn.addEventListener("click", function () {
		if (phase !== "round-draw" || drawingDisabled) return;
		// Push the latest strokes once more for safety, then submit.
		sendStrokes();
		sendCmd({ type: "submit" });
		drawingDisabled = true;
		submitted = true;
		roundDrawSubmitBtn.disabled = true;
		roundUndoBtn.disabled = true;
		roundDrawSubmittedBanner.classList.remove("hidden");
	});

	roundDrawAdvanceBtn.addEventListener("click", function () {
		if (phase !== "round-draw") return;
		sendCmd({ type: "advance" });
	});

	revealNextBtn.addEventListener("click", function () {
		if (phase !== "reveal") return;
		sendCmd({ type: "reveal-advance" });
	});

	endGameBtn.addEventListener("click", function () {
		if (!viewerIsHost) return;
		if (!confirm("End this game for everyone?")) return;
		sendCmd({ type: "end-game" });
	});

	leaveBtn.addEventListener("click", function () {
		if (!confirm("Leave this game?")) return;
		sendCmd({ type: "leave" });
		// Reset the local UI immediately — the user has decided to
		// leave; we don't need server confirmation to take them
		// back to name entry. The leftVoluntarily flag tells the
		// upcoming WS close handler to skip its disconnect/error UI.
		leftVoluntarily = true;
		hideNameError();
		resetToNameEntry();
		try { if (ws) ws.close(); } catch (e) {}
	});

	copyBtn.addEventListener("click", function () {
		const url = shareLink.value;
		const writeText = (navigator.clipboard && navigator.clipboard.writeText)
			? navigator.clipboard.writeText(url)
			: Promise.reject(new Error("no clipboard"));
		writeText.then(function () {
			copyStatus.textContent = "Copied!";
			setTimeout(function () { copyStatus.textContent = ""; }, 1500);
		}).catch(function () {
			shareLink.select();
			copyStatus.textContent = "Selected — press Cmd/Ctrl+C to copy.";
		});
	});
})();
</script>
{{end}}
